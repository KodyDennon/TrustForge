{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trustforge.io/schemas/v0/packet-bundle.schema.json",
  "title": "TrustForge Packet Bundle",
  "description": "A group of related packets (e.g. emergency packet + post-event quorum review) shipped together as a unit, for store-and-forward / air-gap workflows.",
  "type": "object",
  "required": ["bundle_version", "bundle_id", "packets", "signature"],
  "additionalProperties": false,
  "properties": {
    "bundle_version": { "enum": ["1"], "description": "Version of the packet-bundle schema itself." },
    "bundle_id": { "type": "string", "minLength": 1, "description": "Stable bundle identifier." },
    "label": { "type": "string", "description": "Human-readable bundle label." },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "packet.schema.json" },
      "description": "Packets carried by this bundle."
    },
    "transport_hint": {
      "enum": ["usb", "qr-code", "serial", "lora", "file-drop", "manual"],
      "description": "How the bundle is being moved."
    },
    "created_at": { "$ref": "_common.schema.json#/$defs/Timestamp" },
    "signature": { "$ref": "_common.schema.json#/$defs/SignatureEnvelope" }
  }
}
