{
  "name": "@trustforge/stack-auth",
  "version": "0.1.0",
  "type": "module",
  "description": "TrustForge integration for Stack Auth — verifies stack-auth session tokens via @stackframe/stack and projects user.id into a TrustForge actor.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --noEmit",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@trustforge/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@stackframe/stack": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@stackframe/stack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@trustforge/test-utils": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.6.3"
  }
}
