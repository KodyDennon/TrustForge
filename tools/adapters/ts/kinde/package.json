{
  "name": "@trustforge-protocol/kinde",
  "version": "0.1.0",
  "type": "module",
  "description": "TrustForge integration for Kinde — verifies Kinde JWTs via @kinde-oss/kinde-typescript-sdk and projects sub into a TrustForge actor.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --noEmit",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@trustforge-protocol/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@kinde-oss/kinde-typescript-sdk": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@kinde-oss/kinde-typescript-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@trustforge-protocol/test-utils": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.6.3"
  }
