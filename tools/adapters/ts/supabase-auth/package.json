{
  "name": "@trustforge-protocol/supabase-auth",
  "version": "0.1.0",
  "type": "module",
  "description": "TrustForge integration for Supabase Auth — verifies Supabase JWTs via @supabase/supabase-js admin client and projects user.id into a TrustForge actor.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --noEmit",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@trustforge-protocol/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@trustforge-protocol/test-utils": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.6.3"
  }
}
