{
  "name": "@trustforge/auth0",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TrustForge integration for Auth0 — verifies Auth0 JWTs (RS256, JWKS) via jose and projects sub into a TrustForge actor.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --noEmit",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@trustforge/sdk": "workspace:*"
  },
  "peerDependencies": {
    "jose": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "jose": { "optional": true }
  },
  "devDependencies": {
    "@trustforge/test-utils": "workspace:*",
    "@types/bun": "^1.3.9",
    "typescript": "^5.6.3"
  }
}
