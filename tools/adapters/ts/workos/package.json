{
  "name": "@trustforge/workos",
  "version": "0.1.0",
  "type": "module",
  "description": "TrustForge integration for WorkOS — verifies WorkOS access tokens via @workos-inc/node and projects user.id into a TrustForge actor.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --noEmit",
