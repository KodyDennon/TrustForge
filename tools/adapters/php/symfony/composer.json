{
  "name": "trustforge/symfony",
  "description": "TrustForge Symfony bundle: registers a kernel listener that gates HTTP requests via tf-daemon /v1/decide.",
  "type": "symfony-bundle",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": { "TrustForge\\Symfony\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "TrustForge\\Symfony\\Tests\\": "tests/" }
  }
}
