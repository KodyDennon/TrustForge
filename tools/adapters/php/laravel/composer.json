{
  "name": "trustforge/laravel",
  "description": "TrustForge Laravel integration: Service Provider + Middleware that gates HTTP requests via tf-daemon /v1/decide.",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "TrustForge\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TrustForge\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": ["TrustForge\\Laravel\\TrustForgeServiceProvider"]
    }
  }
}
