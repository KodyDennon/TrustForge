#!/bin/sh
# tf-daemon-generator — systemd unit generator for TrustForge instances.
#
# Install path:   /usr/lib/systemd/system-generators/tf-daemon-generator
# Invoked by:     systemd, very early in boot (and on `systemctl daemon-reload`)
#
# Behavior:
#   For every file matching /etc/trustforge/instances/<name>.tf-daemon
#   this script emits a systemd drop-in symlink that activates the
#   corresponding tf-daemon@<name>.service template instance, plus a
#   tiny override that points the daemon at the per-instance config.
#
#   This lets operators declare new daemons by dropping a config file —
#   no manual `systemctl enable tf-daemon@foo` required.
#
# systemd contract for generators:
#   * Generators run very early; PATH may be minimal — stick to POSIX sh
#     and tools shipped in the initrd / base userland.
#   * They MUST NOT block. No network, no daemons, no long IO.
#   * They receive three arguments: normal-dir, early-dir, late-dir.
#     We write into the early-dir (argv[2]) so our units beat regular
#     /etc/systemd/system overrides for ordering, but do not stomp on
#     hand-crafted operator units in /etc.
#   * Exit 0 even on partial failure; log to stderr (-> journal).

set -eu

# systemd hands us three target directories. We only need the early one.
EARLY_DIR="${2:-/tmp}"
INSTANCES_DIR="/etc/trustforge/instances"
WANTS_DIR="${EARLY_DIR}/multi-user.target.wants"

# No instance configs? Nothing to do — exit cleanly.
[ -d "${INSTANCES_DIR}" ] || exit 0

mkdir -p "${WANTS_DIR}" || exit 0

# Iterate *.tf-daemon files. The shell glob can fail-noop if none match.
found=0
for cfg in "${INSTANCES_DIR}"/*.tf-daemon; do
    [ -e "${cfg}" ] || continue
    found=1

    # Strip directory and extension to get the instance name.
    base="${cfg##*/}"
    name="${base%.tf-daemon}"

    # systemd instance names must be escaped (e.g. '/' -> '-'). For now
    # we require operators to use [A-Za-z0-9_-] in instance names; reject
    # anything else loudly so misconfigurations are visible in the journal.
    case "${name}" in
        *[!A-Za-z0-9_-]*|'')
            echo "tf-daemon-generator: skipping invalid instance name: ${name}" >&2
            continue
            ;;
    esac

    unit="tf-daemon@${name}.service"

    # Wire it into multi-user.target so it autostarts at boot.
    ln -sf "/usr/lib/systemd/system/tf-daemon@.service" \
           "${WANTS_DIR}/${unit}"

    # Per-instance drop-in: point ExecStart at the discovered config file.
    dropin_dir="${EARLY_DIR}/${unit}.d"
    mkdir -p "${dropin_dir}"
    {
        printf '%s\n' "# Auto-generated by tf-daemon-generator. Do not edit."
        printf '%s\n' "[Service]"
        printf '%s\n' "ExecStart="
        printf 'ExecStart=/usr/bin/tf-daemon --instance %s --config %s\n' \
               "${name}" "${cfg}"
    } > "${dropin_dir}/10-instance.conf"
done

if [ "${found}" -eq 0 ]; then
    # Quiet success: no instance configs found.
    exit 0
fi

exit 0
