{
  "name": "@trustforge-protocol/schema",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/loader.ts",
  "exports": {
    ".": "./src/loader.ts",
    "./loader": "./src/loader.ts",
    "./validate": "./src/validate.ts"
  },
  "description": "TrustForge schema definition and validation engine. Define strict, verifiable types for capabilities, evidence, and actions.",
  "scripts": {
    "validate": "bun run src/cli.ts validate",
    "validate:all": "bun run src/cli.ts validate-all",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.6.3"
  },
  "author": "Kody Dennon",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KodyDennon/TrustForge.git"
  },
  "homepage": "https://github.com/KodyDennon/TrustForge#readme",
  "bugs": {
    "url": "https://github.com/KodyDennon/TrustForge/issues"
  },
  "keywords": [
    "trustforge",
    "security",
    "zero-trust",
    "authentication",
    "authorization",
    "crypto"
  ]
}
