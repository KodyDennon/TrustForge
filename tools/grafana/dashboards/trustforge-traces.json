{
  "annotations": { "list": [] },
  "description": "TrustForge trace explorer. Pre-filtered to TrustForge service spans (tf.daemon.decide, tf.bridge.import_credential, tf.proof.sign, tf.proof.verify, tf.session.handshake/tick, tf.evidence.assemble/verify) with span-attribute breakdowns by tf.action, tf.decision, tf.actor_resolved.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "queryType": "search",
        "showTraceTable": true
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "limit": 50,
          "query": "{ resource.service.name=~\"$service\" && name=~\"tf\\\\.(daemon\\\\.decide|bridge\\\\.import_credential|proof\\\\.(sign|verify)|session\\\\.(handshake|tick)|evidence\\\\.(assemble|verify))\" }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "TrustForge spans (tempo)",
      "type": "traces"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (method) (rate(tf_decisions_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "title": "Decide rate by tf.action / method",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "topk(10, sum by (actor) (rate(tf_decisions_total{service=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{actor}}",
          "refId": "A"
        }
      ],
      "title": "Top-10 actors by decision rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["trustforge", "traces"],
