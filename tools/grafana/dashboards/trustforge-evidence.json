{
  "annotations": { "list": [] },
  "description": "Evidence pipeline (TF-0012 compliance evidence): bundles assembled per second, sealing latency, redaction count, verification failures. Source metrics are tf_proof_events_total (filtered to evidence.*) plus tf.evidence.assemble / tf.evidence.verify spans.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(tf_proof_events_total{service=~\"$service\",type=\"evidence.assemble.ok\"}[$__rate_interval]))",
          "legendFormat": "bundles / sec",
          "refId": "A"
        }
      ],
      "title": "Evidence bundles assembled per second",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(tf_decisions_latency_seconds_bucket{service=~\"$service\",method=\"tf.evidence.assemble\"}[$__rate_interval])))",
          "legendFormat": "p50 sealing",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(tf_decisions_latency_seconds_bucket{service=~\"$service\",method=\"tf.evidence.assemble\"}[$__rate_interval])))",
          "legendFormat": "p95 sealing",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(tf_decisions_latency_seconds_bucket{service=~\"$service\",method=\"tf.evidence.assemble\"}[$__rate_interval])))",
          "legendFormat": "p99 sealing",
          "refId": "C"
        }
      ],
      "title": "Sealing latency (tf.evidence.assemble)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (redaction_class) (increase(tf_proof_events_total{service=~\"$service\",type=\"evidence.redact\"}[$__range]))",
          "legendFormat": "{{redaction_class}}",
          "refId": "A"
        }
      ],
      "title": "Redactions (cumulative over selected range)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(tf_proof_events_total{service=~\"$service\",type=\"evidence.verify.error\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "title": "Evidence verification failures (per second)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["trustforge", "evidence"],
