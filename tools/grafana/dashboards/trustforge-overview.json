        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(tf_decisions_total{service=~\"$service\",instance=~\"$instance\",decision=\"deny\"}[$__rate_interval])) / sum(rate(tf_decisions_total{service=~\"$service\",instance=~\"$instance\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "title": "Deny rate (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
