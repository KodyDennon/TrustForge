      "id": 5,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (peer_domain) (rate(tf_proof_events_total{service=~\"$service\",type=\"federation.handshake.ok\"}[$__rate_interval]))",
          "legendFormat": "{{peer_domain}}",
          "refId": "A"
        }
      ],
      "title": "Federation handshake success rate",
      "type": "timeseries"
    }
  ],
