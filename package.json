  },
  "engines": {
    "bun": ">=1.3"
  },
  "author": "Kody Dennon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KodyDennon/TrustForge.git"
  },
  "homepage": "https://github.com/KodyDennon/TrustForge#readme",
  "bugs": {
    "url": "https://github.com/KodyDennon/TrustForge/issues"
  },
  "keywords": [
    "trustforge",
    "security",
    "zero-trust",
    "authentication",
    "authorization",
    "crypto"
  ]
}
